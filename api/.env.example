# Postgres is exposed on host port 5433 (avoids macOS system Postgres on 5432).
# Use this URL from your shell / uvicorn running on the host.
DATABASE_URL=postgresql+asyncpg://shredder:shredder@localhost:5433/shredder

# When the api runs inside docker-compose, swap host to the service name:
# DATABASE_URL=postgresql+asyncpg://shredder:shredder@postgres:5432/shredder

API_HOST=127.0.0.1
API_PORT=8000
ENGINE_BINARY=../engine/build/shredder
